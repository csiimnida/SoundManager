<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="True">
    <ui:VisualElement name="SoundItem" style="flex-direction: row; align-items: center; width: 100%; min-width: 0; overflow: hidden; padding-left: 4px; padding-right: 2px; padding-top: 2px; padding-bottom: 2px;">
        <ui:VisualElement name="TypeDot" style="width: 8px; height: 8px; flex-shrink: 0; border-top-left-radius: 4px; border-top-right-radius: 4px; border-bottom-right-radius: 4px; border-bottom-left-radius: 4px; margin-right: 6px;" />
        <ui:VisualElement name="NameContainer" style="flex-grow: 1; flex-shrink: 1; min-width: 0; overflow: hidden;">
            <ui:Label text="SoundName" name="SoundName" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;" />
        </ui:VisualElement>
        <ui:Button text="✕" name="DeleteBtn" style="flex-shrink: 0; width: 22px; min-width: 22px; height: 20px; margin-left: 4px; padding-left: 0; padding-right: 0;" />
    </ui:VisualElement>
</ui:UXML>
